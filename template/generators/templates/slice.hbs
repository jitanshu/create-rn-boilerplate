import { createSlice, PayloadAction } from '@reduxjs/toolkit';

interface {{pascalCase name}}State {
  isLoading: boolean;
  error:     string | null;
}

const initialState: {{pascalCase name}}State = {
  isLoading: false,
  error:     null,
};

const {{camelCase name}}Slice = createSlice({
  name: '{{camelCase name}}',
  initialState,
  reducers: {
    setLoading(state, action: PayloadAction<boolean>) {
      state.isLoading = action.payload;
    },
    setError(state, action: PayloadAction<string | null>) {
      state.error = action.payload;
    },
    reset() {
      return initialState;
    },
  },
});

export const { setLoading, setError, reset } = {{camelCase name}}Slice.actions;
export default {{camelCase name}}Slice.reducer;
